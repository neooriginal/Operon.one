{
  "filesystem": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
    "timeout": 30000,
    "autoRestart": true,
    "description": "File system operations for reading and writing files"
  },
  "git": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-git", "--repository", "."],
    "timeout": 30000,
    "autoRestart": true,
    "description": "Git repository operations and version control"
  },
  "brave-search": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-brave-search"],
    "env": {
      "BRAVE_API_KEY": ""
    },
    "timeout": 30000,
    "autoRestart": true,
    "description": "Web search capabilities via Brave Search API"
  },
  "github": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": ""
    },
    "timeout": 30000,
    "autoRestart": true,
    "description": "GitHub repository and issue management"
  },
  "postgres": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-postgres"],
    "env": {
      "POSTGRES_CONNECTION_STRING": ""
    },
    "timeout": 30000,
    "autoRestart": true,
    "description": "PostgreSQL database operations",
    "enabled": false
  },
  "sqlite": {
    "command": "npx", 
    "args": ["-y", "@modelcontextprotocol/server-sqlite", "--db-path", "./data/database.db"],
    "timeout": 30000,
    "autoRestart": true,
    "description": "SQLite database operations"
  },
  "memory": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-memory"],
    "timeout": 30000,
    "autoRestart": true,
    "description": "Persistent memory and context management"
  },
  "puppeteer": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
    "timeout": 30000,
    "autoRestart": true,
    "description": "Web automation and scraping capabilities"
  },
  "fetch": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-fetch"],
    "timeout": 30000,
    "autoRestart": true,
    "description": "HTTP requests and API interactions"
  },
  "time": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-time"],
    "timeout": 30000,
    "autoRestart": true,
    "description": "Time and date utilities"
  }
}